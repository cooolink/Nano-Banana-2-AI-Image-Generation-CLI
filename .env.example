# Nano Banana 2 - Environment Configuration
# Copy this file to ~/.nano-banana/.env and fill in your API key

# =============================================================================
# OPTION 1: Poyo AI (Recommended)
# =============================================================================
# Get your API key from: https://poyo.ai
# Provides access to Nano Banana 2 models with async task processing

GEMINI_API_KEY=your_poyo_api_key_here
GEMINI_BASE_URL=https://api.poyo.ai

# Available models:
# - nano-banana-2-new (alias: new) - Text-to-image and image-to-image
# - nano-banana-2-new-edit (alias: edit) - Advanced image editing

# =============================================================================
# OPTION 2: Google Gemini (Legacy)
# =============================================================================
# Get your API key from: https://aistudio.google.com/apikey
# Provides access to Gemini 3.1 Flash and Gemini 3 Pro models

# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_BASE_URL=  # Leave empty or comment out for Google Gemini

# Available models:
# - gemini-3.1-flash-image-preview (alias: flash, nb2) - Fast & cheap
# - gemini-3-pro-image-preview (alias: pro, nb-pro) - Highest quality

# =============================================================================
# Configuration Notes
# =============================================================================
#
# 1. API Key Format:
#    - Poyo AI: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#    - Google Gemini: AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 2. Base URL:
#    - Set to https://api.poyo.ai for Poyo AI
#    - Leave empty or comment out for Google Gemini
#
# 3. Installation:
#    mkdir -p ~/.nano-banana
#    cp .env.example ~/.nano-banana/.env
#    # Edit ~/.nano-banana/.env with your API key
#
# 4. Priority:
#    The CLI checks for configuration in this order:
#    - Command line --api-key flag
#    - GEMINI_API_KEY environment variable
#    - .env file in current directory
#    - .env file in repo root
#    - ~/.nano-banana/.env (recommended)
#
# =============================================================================
